# Lowe's Channel Configuration
# Copy this to .env.local and add your API keys, or set in Vercel Environment Variables

## Email (for quote submission)
# RESEND_API_KEY=your_resend_key
QUOTE_EMAIL_TO=proquote@americanbathgroup.com

# Chat (Claude API)
# ANTHROPIC_API_KEY=your_anthropic_key

# Site
NEXT_PUBLIC_SITE_NAME=Lowe's Pro Sales Portal

# Channel — Lowe's brands: MAAX, Mr. Steam, Clarion, Aker, Mansfield
NEXT_PUBLIC_CHANNEL=lowes
